generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AGENT
  USER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_MANUAL_REVIEW
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketCategory {
  BUG
  FEATURE_REQUEST
  SUPPORT
  BILLING
  OTHER
}

enum AiStatus {
  PENDING
  CLASSIFIED
  FAILED
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String
  role           UserRole @default(USER)
  isActive       Boolean  @default(true)
  emailVerified  Boolean  @default(false)
  verificationToken   String?
  verificationExpires DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  refreshToken   String?

  tickets        Ticket[]       @relation("CreatedTickets")
  assignedTickets Ticket[]      @relation("AssignedTickets")
  auditLogs      AuditLog[]
  comments       Comment[]
  notifications  Notification[]
  passwordResets PasswordReset[]
  attachments    Attachment[]

  @@map("users")
}

model Ticket {
  id          String          @id @default(uuid())
  title       String
  description String
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority?
  category    TicketCategory?
  aiResponse  String?
  aiStatus    AiStatus        @default(PENDING)
  confidence  Float?

  createdById String
  createdBy   User            @relation("CreatedTickets", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?          @relation("AssignedTickets", fields: [assignedToId], references: [id])

  firstResponseAt DateTime?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  auditLogs   AuditLog[]
  aiResults   AiResult[]
  comments    Comment[]
  attachments Attachment[]
  ticketReads TicketRead[]

  @@index([status])
  @@index([priority])
  @@index([createdById])
  @@index([assignedToId])
  @@index([aiStatus])
  @@index([createdAt])
  @@index([confidence])
  @@index([aiStatus, confidence])
  @@index([assignedToId, status])
  @@map("tickets")
}

model AiResult {
  id                String         @id @default(uuid())
  ticketId          String
  ticket            Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  provider          String
  category          TicketCategory
  priority          TicketPriority
  suggestedResponse String
  confidence        Float
  accepted          Boolean?
  createdAt         DateTime       @default(now())

  @@index([ticketId])
  @@map("ai_results")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  field     String?
  oldValue  String?
  newValue  String?

  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([userId])
  @@map("audit_logs")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
  @@index([userId])
  @@map("comments")
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  title     String
  message   String
  ticketId  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

model PasswordReset {
  id        String    @id @default(uuid())
  tokenHash String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId])
  @@map("password_resets")
}

model Attachment {
  id           String   @id @default(uuid())
  filename     String
  storagePath  String
  mimeType     String
  size         Int
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([ticketId])
  @@map("attachments")
}

model Outbox {
  id        String   @id @default(uuid())
  event     String
  payload   Json
  published Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([published, createdAt])
  @@map("outbox")
}

model SlaConfig {
  id                 String         @id @default(uuid())
  priority           TicketPriority @unique
  maxResponseMinutes Int
  updatedAt          DateTime       @updatedAt

  @@map("sla_configs")
}

model TicketRead {
  userId     String
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@id([userId, ticketId])
  @@index([userId])
  @@map("ticket_reads")
}
